# ═══════════════════════════════════════════════════════════════════════════
# ⚡ SUPREME JARVIS — Environment Configuration
# ═══════════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your keys.
# Lines starting with # are comments. Remove the # to activate a setting.

# ───────────────────────────────────────────────────────────────────────────
# 🤖 LLM PROVIDER SELECTION
# ───────────────────────────────────────────────────────────────────────────
# Choose which provider to use: anthropic (default) | openai | gemini | router
# "router" auto-selects based on model name prefix or task type.
AGENCY_PROVIDER=anthropic

# ───────────────────────────────────────────────────────────────────────────
# 🔑 API KEYS — fill in the providers you want to use
# ───────────────────────────────────────────────────────────────────────────

# Anthropic Claude (default engine)
# Get yours at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI GPT-4o
# Get yours at: https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-...

# Google Gemini
# Get yours at: https://aistudio.google.com/app/apikey
# GOOGLE_API_KEY=AIza...

# ───────────────────────────────────────────────────────────────────────────
# 🧠 MODEL SELECTION
# ───────────────────────────────────────────────────────────────────────────
# Main (high-capability) model
AGENCY_MODEL=claude-opus-4-7

# Fast/cheap model for routing decisions
AGENCY_PLANNER_MODEL=claude-haiku-4-5

# Override per-provider defaults
# OPENAI_MODEL=gpt-4o
# GEMINI_MODEL=gemini-2.0-flash

# Max tokens per response (increase for long tasks)
AGENCY_MAX_TOKENS=16000

# Agentic task budget — enable extended thinking loops (>= 20000)
# AGENCY_TASK_BUDGET=20000

# ───────────────────────────────────────────────────────────────────────────
# 🛡️ TRUST & PERMISSIONS
# ───────────────────────────────────────────────────────────────────────────
# Trust mode: off | on-my-machine | yolo
# "yolo" = full access: shell, file IO, web, computer use (use on your own machine only)
AGENCY_TRUST_MODE=on-my-machine

# Allow shell command execution
AGENCY_ALLOW_SHELL=1

# ───────────────────────────────────────────────────────────────────────────
# 🌐 CAPABILITIES
# ───────────────────────────────────────────────────────────────────────────
# Enable Anthropic's built-in web search tool
AGENCY_ENABLE_WEB_SEARCH=1

# Enable Anthropic's server-side code execution
AGENCY_ENABLE_CODE_EXECUTION=1

# Enable computer use (screenshot + click automation)
AGENCY_ENABLE_COMPUTER_USE=1

# ───────────────────────────────────────────────────────────────────────────
# 📊 TRACING & OBSERVABILITY
# ───────────────────────────────────────────────────────────────────────────
# Enable OpenTelemetry tracing (auto-enabled if opentelemetry is installed)
AGENCY_ENABLE_TRACING=1

# OTLP endpoint — AI Toolkit uses http://localhost:4318 by default
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# Service name shown in trace viewer
OTEL_SERVICE_NAME=jarvis-agency

# ───────────────────────────────────────────────────────────────────────────
# 🧪 EVALUATION
# ───────────────────────────────────────────────────────────────────────────
# Use LLM judge for evaluation (costs tokens; heuristic is free)
# AGENCY_EVAL_LLM_JUDGE=1

# ───────────────────────────────────────────────────────────────────────────
# 🧠 JARVIS BRAIN
# ───────────────────────────────────────────────────────────────────────────
# Path to jarvis markdown modules (defaults to ../jarvis relative to runtime)
# JARVIS_DIR=C:\Users\User\agency\jarvis

# ───────────────────────────────────────────────────────────────────────────
# 🌐 MCP SERVERS (optional — JSON array)
# ───────────────────────────────────────────────────────────────────────────
# Connect external MCP servers (filesystem, browser, etc.)
# AGENCY_MCP_SERVERS=[{"type":"url","url":"https://...","name":"..."}]

# ───────────────────────────────────────────────────────────────────────────
# 🚀 SERVER
# ───────────────────────────────────────────────────────────────────────────
# Port for the web UI / API server
AGENCY_PORT=8765
